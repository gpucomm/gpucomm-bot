# Server
PORT=3000
HOST=127.0.0.1

# Webhook (set this in GitHub webhook settings)
WEBHOOK_SECRET=your_webhook_secret_here

# GitHub App (create a GitHub App in org settings)
GITHUB_APP_ID=123456
GITHUB_INSTALLATION_ID=987654
# Base64-encoded private key PEM (generate with: base64 -i private-key.pem)
GITHUB_PRIVATE_KEY_B64=

# Optional: GitHub Enterprise (for github.com leave empty)
GITHUB_API_URL=

# Optional: Label to apply to GPU-related PRs (must already exist in repo)
GPUCOMM_GPU_LABEL=gpu-required
